{
  "name": "gigaverse3d-learncode-python",
  "version": "0.1.0",
  "description": "Curso interativo de terminal que ensina Python capítulo por capítulo (Pense em Python 2e + módulo funcional), rodando código Python de verdade.",
  "type": "module",
  "bin": {
    "learncode-python": "dist/src/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "execa": "^9.6.1",
    "ink": "^5.2.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
